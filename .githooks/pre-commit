#!/usr/bin/env bash
# Pre-commit hook: valida i18n + voz de marca antes de permitir el commit.
# Se ejecuta solo cuando hay cambios staged en archivos .js/.jsx/.ts/.tsx
# o en lib/dictionaries.js.
#
# Instalación (una sola vez por clon del repo):
#   git config core.hooksPath .githooks
#
# Para saltarse en emergencias:
#   git commit --no-verify

set -e

# Detectar archivos relevantes en staging
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx)$' || true)

if [ -z "$STAGED" ]; then
  # No hay archivos relevantes → saltar validación
  exit 0
fi

echo "🔍 Pre-commit: validando i18n + voz de marca..."

if ! npm run --silent lint:i18n:ci; then
  echo ""
  echo "❌ El linter i18n/voz de marca detectó problemas."
  echo "   Arregla los issues reportados arriba antes de commitear,"
  echo "   o usa 'git commit --no-verify' si es una emergencia."
  echo ""
  exit 1
fi

echo "✅ Pre-commit: diccionario limpio."
exit 0
